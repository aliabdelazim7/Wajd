# ─── قاعدة البيانات ───────────────────────────────────────────────────────────
# رابط PostgreSQL الكامل
DATABASE_URL=postgresql://username:password@localhost:5432/wajd_db

# ─── خادم API ─────────────────────────────────────────────────────────────────
# رقم المنفذ لخادم API
PORT=8080

# بيئة التشغيل: development | production
NODE_ENV=development

# مفتاح سري للجلسات (استخدم نصاً عشوائياً طويلاً)
SESSION_SECRET=change_this_to_a_long_random_secret_string

# ─── الموقع الأمامي ──────────────────────────────────────────────────────────
# رقم منفذ الموقع الأمامي (للتطوير)
FRONTEND_PORT=3000

# المسار الأساسي للموقع (/ للجذر)
BASE_PATH=/
